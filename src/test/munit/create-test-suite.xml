	<munit:config name="create-test-suite.xml" />
	<munit:test name="create-success-test-suiteTest" doc:id="45f7339f-d410-4bd9-aae8-a83a1db52517">
		<munit:behavior >
			<munit-tools:mock-when doc:name="apikit:router" doc:id="61b5304c-b3db-4bda-bb6d-504228d3bf15" processor="apikit:router">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="sapi-salesforce-config" attributeName="config-ref" />
				</munit-tools:with-attributes>
				<munit-tools:then-call flow="post:\create:application\json:sapi-salesforce-config" />
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="salesforce:create" doc:id="e94deb2d-c83f-41ec-8ef8-903926f84a33" processor="salesforce:create">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Create" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="df2dd956-dadf-4c2e-8f89-9d150abdd5d7" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value='#[output application/json --- readUrl("classpath://create/successResponse.dwl")]' mediaType="application/json" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="ea115ebc-eaac-44b9-acf9-635b0aa4765f" >
				<munit:payload value='#[output application/json --- readUrl("classpath://create/payload.dwl")]' mediaType="application/json" />
